{
  "name": "browniebee-crm",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --prefix api",
    "dev:web": "npm run dev --prefix frontend",
    "build": "npm run build:api",
    "build:api": "npm install --prefix api --omit=dev && echo API ready for deploy",
    "build:web": "npm run build --prefix frontend",
    "start": "npm run start --prefix api",
    "install:all": "npm install --prefix frontend && npm install --prefix api",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
